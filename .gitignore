# Bundler cache
.bundle
vendor
# Gemfile.lock IS committed for reproducible CI builds.
# It must contain BOTH platforms (local Windows + CI Ubuntu). After changing
# gems, run:  bundle lock --add-platform x86_64-linux
# A Windows-only lock breaks the "Setup Ruby" step on the Ubuntu runner.

# Jekyll cache
.jekyll-cache
.jekyll-metadata
_site

# RubyGems
*.gem

# NPM dependencies
node_modules
package-lock.json

# IDE configurations
.idea
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json

# Misc
_sass/vendors
assets/js/dist
